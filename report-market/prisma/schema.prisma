generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Enums ====================

enum UserRole {
  CARRIER
  DISPATCHER
}

enum ReportCategory {
  TRANSPORT
  PROFESSIONAL
  COMMUNICATION
  COMPLIANCE
  SAFETY
}

enum ReportSubcategory {
  // Transport (load/scheduling)
  LATE_DELIVERY
  LOAD_CANCELLATION
  POOR_SCHEDULE
  NO_GOOD_TO_GO
  REFUSES_DETENTION
  FAILS_TO_REPORT
  NOT_CHECKING_LOAD
  DOING_PARTIALS
  // Professional (behavior/conduct)
  PUNCTUALITY
  IRRESPONSIBILITY
  RUDE_BEHAVIOR
  HIGH_RATES
  DIRECT_CONTACT
  THREATENS_DELIVERY
  IGNORING_INSTRUCTIONS
  // Communication
  COMMUNICATION
  POOR_COMMUNICATION
  LACK_OF_UNDERSTANDING
  LANGUAGE_BARRIER
  // Compliance (docs/tracking/procedures)
  DOCUMENTATION
  DOT_INSPECTION_ISSUE
  INVALID_DOCUMENTS
  NO_TRACKING
  GPS_OFF
  REFUSES_SEAL
  // Safety
  CARGO_DAMAGE
  ACCIDENT
  UNSAFE_DRIVING
  POOR_EQUIPMENT
}

enum ReportStatus {
  PENDING
  VERIFIED
  DISPUTE_PENDING
  DISPUTED
}

// ==================== Auth.js Models ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== Application Models ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  role          UserRole  @default(CARRIER)
  companyName   String?
  mcNumber      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  reports  Report[]
}

model Driver {
  id        String   @id @default(cuid())
  cdlNumber String   @unique
  firstName String?
  lastName  String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports Report[]

  @@index([cdlNumber])
}

model Report {
  id            String              @id @default(cuid())
  subcategories ReportSubcategory[]
  description   String              @db.Text
  incidentDate DateTime
  status        ReportStatus      @default(VERIFIED)
  disputeReason String?           @db.Text
  disputedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  driverId   String
  driver     Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([reporterId])
}
